{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jakeraft.github.io/clier-qa/schema/report-v2.schema.json",
  "title": "clier QA Report (v2)",
  "description": "Structured QA run output. Decouples deterministic script checks from agent qualitative judgment. Rendered by the clier-qa site into HTML on the client side.",
  "type": "object",
  "required": ["schema_version", "run", "taxonomy", "checks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 2,
      "description": "Fixed at 2. Renderer refuses unknown major versions; minor extensions within v2 must be additive."
    },

    "run": {
      "type": "object",
      "required": ["id", "started_at", "finished_at", "environment", "agent"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique run identifier. Recommended: same value as the report filename stem (e.g. 2026-04-18T095435)."
        },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "environment": {
          "type": "object",
          "required": ["os", "clier_version", "auth_target", "disposable_prefix"],
          "additionalProperties": false,
          "properties": {
            "os": { "type": "string", "description": "e.g. 'Darwin 24.5.0'" },
            "clier_version": { "type": "string" },
            "auth_target": { "type": "string", "description": "Authenticated org/user, e.g. '@clier'" },
            "disposable_prefix": {
              "type": "string",
              "description": "Unique prefix for all disposable resources created in this run. Used for cleanup verification."
            },
            "modes_exercised": {
              "type": "array",
              "items": { "enum": ["agent", "user"] },
              "uniqueItems": true
            }
          }
        },
        "agent": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["claude", "codex"] },
            "model": { "type": "string" }
          }
        }
      }
    },

    "taxonomy": {
      "type": "object",
      "required": ["phases"],
      "additionalProperties": false,
      "properties": {
        "phases": {
          "type": "array",
          "description": "Declarative phase list. Renderer groups checks by phase.id and orders by phase.order.",
          "items": {
            "type": "object",
            "required": ["id", "name", "order"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "name": { "type": "string" },
              "order": { "type": "integer", "minimum": 0 },
              "stripe": {
                "enum": ["agent", "user"],
                "description": "Optional rendering hint for left-border color. Omit for default gray."
              }
            }
          },
          "minItems": 1
        }
      }
    },

    "checks": {
      "type": "array",
      "description": "Atomic units of verification. Aggregate totals and per-phase chips are derived from this list.",
      "items": { "$ref": "#/$defs/check" }
    },

    "notes": {
      "type": "array",
      "description": "Free-form narrative paragraphs, phase-tagged. Renderer shows them in the phase card as prose.",
      "items": { "$ref": "#/$defs/note" }
    },

    "artifacts": {
      "type": "array",
      "description": "Structured non-check observations: tables, checklists, key/value blocks.",
      "items": { "$ref": "#/$defs/artifact" }
    }
  },

  "$defs": {

    "status": {
      "enum": ["pass", "fail", "skip", "error"],
      "description": "pass: asserted and passed. fail: asserted and failed. skip: not exercised (intentional or prior-step failure). error: test machinery failure, outcome unknown."
    },

    "guidance": {
      "enum": ["good", "poor", "missing"],
      "description": "Agent's rating of user-facing error message quality. GOOD explains + guides, POOR explains only, MISSING cryptic or absent."
    },

    "expectation": {
      "type": "object",
      "required": ["kind", "pass"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "exit_code",
            "stdout_contains",
            "stderr_contains",
            "stdout_matches",
            "stderr_matches",
            "json_path_exists",
            "json_path_equals",
            "json_path_matches",
            "custom"
          ]
        },
        "expected": {
          "description": "Expected value or pattern. String for text assertions, number for numeric, any for json_path_equals. For json_path_* assertions pair with 'path'."
        },
        "actual": {
          "description": "Observed value. Omit if obvious from evidence (e.g. exit_code already stored at evidence-level)."
        },
        "path": {
          "type": "string",
          "description": "JSONPath expression, required for json_path_* kinds."
        },
        "pass": { "type": "boolean" },
        "note": { "type": "string", "description": "Free-form explanation for 'custom' kind or caveats." }
      }
    },

    "check": {
      "type": "object",
      "required": ["id", "phase", "source", "status", "title", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)*$",
          "description": "Stable dotted id, e.g. 'guards.double-start-refuse'. Used for cross-run tracking and deep-links."
        },
        "phase": {
          "type": "string",
          "description": "Must match a taxonomy.phases[].id."
        },
        "source": {
          "enum": ["script", "agent"],
          "description": "Who decides the verdict. Script-run setup + agent-judged outcome ⇒ 'agent'."
        },
        "status": { "$ref": "#/$defs/status" },
        "title": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Free-form cross-cutting tags (e.g. 'version', 'workspace', 'tty-required')."
        },
        "guidance": { "$ref": "#/$defs/guidance" },
        "rationale": {
          "type": "string",
          "description": "Agent-written explanation. Required for source=agent; useful on any fail/error."
        },
        "fail_note": {
          "type": "string",
          "description": "Symptom + user-facing impact. Required when status=fail."
        },
        "skip_reason": {
          "type": "string",
          "description": "Why skipped (environmental limit, prior step failed, etc.). Required when status=skip."
        },
        "error_detail": {
          "type": "string",
          "description": "What broke in the test machinery. Required when status=error."
        },
        "evidence": {
          "oneOf": [
            { "$ref": "#/$defs/evidenceCommand" },
            { "$ref": "#/$defs/evidenceScenario" },
            { "$ref": "#/$defs/evidenceObservation" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "fail" } }, "required": ["status"] },
          "then": { "required": ["fail_note"] }
        },
        {
          "if": { "properties": { "status": { "const": "skip" } }, "required": ["status"] },
          "then": { "required": ["skip_reason"] }
        },
        {
          "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
          "then": { "required": ["error_detail"] }
        },
        {
          "if": { "properties": { "source": { "const": "agent" } }, "required": ["source"] },
          "then": { "required": ["rationale"] }
        }
      ]
    },

    "evidenceCommand": {
      "type": "object",
      "required": ["kind", "command"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "command" },
        "command": { "type": "string" },
        "exit_code": { "type": "integer" },
        "stdout_excerpt": { "type": "string" },
        "stderr_excerpt": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" }
        }
      }
    },

    "evidenceScenario": {
      "type": "object",
      "required": ["kind", "steps"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "scenario" },
        "precondition": {
          "type": "string",
          "description": "Human-readable summary of what must be true before this scenario starts."
        },
        "expected_outcome": {
          "type": "string",
          "description": "Human-readable summary of what the assertion steps verify, shown as the card subtitle."
        },
        "actual_outcome": {
          "type": "string",
          "description": "Human-readable summary of what was observed. Compared to expected_outcome in the UI."
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        }
      }
    },

    "evidenceObservation": {
      "type": "object",
      "required": ["kind", "rationale"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "observation" },
        "rationale": {
          "type": "string",
          "description": "Agent's qualitative observation with no command execution (e.g. 'tutorial copy is consistent with reality')."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": false,
            "properties": {
              "kind": { "enum": ["help_output", "tutorial_step", "doc_excerpt", "url"] },
              "label": { "type": "string" },
              "excerpt": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },

    "step": {
      "type": "object",
      "required": ["role", "label", "status"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "enum": ["setup", "action", "assertion", "teardown"],
          "description": "setup: precondition. action: user-visible command. assertion: verifies expected outcome. teardown: cleanup."
        },
        "label": { "type": "string" },
        "command": { "type": "string" },
        "fs_op": {
          "type": "object",
          "description": "Non-CLI filesystem operation performed as part of the step (edit, write, remove).",
          "required": ["kind", "path"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["write", "edit", "remove", "chmod"] },
            "path": { "type": "string" },
            "summary": { "type": "string" }
          }
        },
        "exit_code": { "type": "integer" },
        "stdout_excerpt": { "type": "string" },
        "stderr_excerpt": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "captured": {
          "type": "object",
          "description": "Key/value pairs extracted from this step's output, referenced by later steps via '{captured.key}' token substitution in expectations. Never include secrets.",
          "additionalProperties": { "type": ["string", "number", "boolean"] }
        },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" },
          "description": "Typically only present on role=assertion steps."
        },
        "status": { "$ref": "#/$defs/status" },
        "skip_reason": { "type": "string" },
        "error_detail": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "skip" } }, "required": ["status"] },
          "then": { "required": ["skip_reason"] }
        },
        {
          "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
          "then": { "required": ["error_detail"] }
        }
      ]
    },

    "note": {
      "type": "object",
      "required": ["kind", "body"],
      "additionalProperties": false,
      "properties": {
        "phase": {
          "type": ["string", "null"],
          "description": "taxonomy.phases[].id, or null for report-level (e.g. exploratory summary)."
        },
        "kind": {
          "enum": ["exploratory", "summary", "detail", "warning"],
          "description": "Renderer uses this to pick styling. 'warning' is highlighted."
        },
        "subhead": { "type": "string", "description": "Optional inline subheading inside the phase card." },
        "body": { "type": "string", "description": "Plain text or light markdown (bold, italic, inline code, lists)." }
      }
    },

    "artifact": {
      "oneOf": [
        { "$ref": "#/$defs/artifactTable" },
        { "$ref": "#/$defs/artifactChecklist" },
        { "$ref": "#/$defs/artifactKV" }
      ]
    },

    "artifactTable": {
      "type": "object",
      "required": ["kind", "columns", "rows"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "table" },
        "phase": { "type": ["string", "null"] },
        "subhead": { "type": "string" },
        "columns": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "Keys should match column names; values are strings/numbers.",
            "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      }
    },

    "artifactChecklist": {
      "type": "object",
      "required": ["kind", "items"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "checklist" },
        "phase": { "type": ["string", "null"] },
        "subhead": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "status"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "status": { "$ref": "#/$defs/status" },
              "note": { "type": "string" }
            }
          },
          "minItems": 1
        }
      }
    },

    "artifactKV": {
      "type": "object",
      "required": ["kind", "pairs"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "kv" },
        "phase": { "type": ["string", "null"] },
        "subhead": { "type": "string" },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string" },
              "value": { "type": ["string", "number", "boolean", "null"] }
            }
          }
        }
      }
    }
  }
}
